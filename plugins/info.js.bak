// info.js
const {
    cmd
} = require('../command');
const config = require('../config');
const prefix = config.PREFIX;

cmd({
    pattern: 'tofan',
    alias: ['tofaninfo', 'info', 'manual'],
    desc: 'Information on how to use the bot.',
    category: 'setting',
    filename: __filename
}, async (bot, message, client, {
    from,
    reply
}) => {
    try {
        const ownerNumber = '+923151105391';
        const ownerName = '𝚀𝙰𝙳𝙴𝙴𝚁 𝙺𝙷𝙰𝙽 🤖';
        const vcard = `BEGIN:VCARD
VERSION:3.0
FN:${ownerName}
TEL;type=CELL;type=VOICE;waid=${ownerNumber.replace('+', '')}:${ownerNumber}
END:VCARD`;

        const infoText = `🔹 *Welcome to QADEER AI Bot!* *(please read all)* 🔹

*Here’s how you can make the best use of the bot (please read all):*

1️⃣ Use *${prefix}list* to get a list of available commands and their descriptions.
2️⃣ Use *${prefix}help* to get information about a command.
3️⃣ Use *${prefix}report* if you encounter any issues or if a command isn't working.
4️⃣ Use *${prefix}checkupdate* to check for available updates.
6️⃣ For any other inquiries, just reach out to the bot owner.
7️⃣ Use *${prefix}request* to suggest a new command or feature you'd like added.
8️⃣ *Note:* The bot is constantly being updated, so keep an eye out for new features and improvements!
9️⃣ Use *${prefix}update* to update bot and use *getpair* to connect your number to my bot for session id.

*Visit our website for more information and to get session id:* https://patron-md.vercel.app

📰 *Join our Channel* for the latest updates on new features and announcements:
🔗 [Join Channel](https://whatsapp.com/channel/0029VajWxSZ96H4SyQLurV1H)

💡 *Also* You should share the bot with your friends and join our support channel for updates.

*Please if you encounter any issue in a command please use ${prefix}report (command). PLEASE*

`;

        await bot.sendMessage(from, {
            text: infoText
        });
        await bot.sendMessage(from, {
            contacts: {
                displayName: ownerName,
                contacts: [{
                    vcard
                }]
            }
        });

    } catch (error) {
        console.error('Error in patron command:', error);
        await bot.sendMessage(from, {
            text: '❌ Something went wrong while retrieving the information.'
        });
    }
});
